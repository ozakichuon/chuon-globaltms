# Copy this to .env.local and fill in your Supabase credentials.
# For local dev with Supabase CLI + Docker: run `supabase start` then copy the values it prints.
# For cloud Supabase: https://supabase.com/dashboard

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App config
NEXT_PUBLIC_APP_NAME="中温タレントマネジメント"
NEXT_PUBLIC_APP_URL=http://localhost:3000
